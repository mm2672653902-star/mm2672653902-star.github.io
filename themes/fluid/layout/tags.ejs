<%
page.layout = "tags"
page.title = theme.tag.title || __('tag.title')
page.subtitle = theme.tag.subtitle || __('tag.subtitle')
page.banner_img = theme.tag.banner_img
page.banner_img_height = theme.tag.banner_img_height
page.banner_mask_alpha = theme.tag.banner_mask_alpha

var min_font = theme.tag.tagcloud.min_font || 15
var max_font = theme.tag.tagcloud.max_font || 30
var unit = theme.tag.tagcloud.unit || 'px'

// 1. Get tags from site.data.tags
let allTagNames = [];
if (site.data && site.data.tags && Array.isArray(site.data.tags)) {
  allTagNames = [...site.data.tags];
} else {
  allTagNames = ["光电信息", "AI工具", "学习心得"];
}

// 2. Merge with any tags currently used in site.tags
site.tags.forEach(function(tag) {
  if (!allTagNames.includes(tag.name)) {
    allTagNames.push(tag.name);
  }
});

// 3. Sort alphabetically
allTagNames.sort(function(a, b) {
  return a.localeCompare(b, 'zh');
});
%>

<div class="tag-cloud-list text-center" style="padding: 20px 0;">
  <% allTagNames.forEach(function(tagName) {
       var hexoTag = site.tags.findOne({ name: tagName });
       var count = hexoTag ? hexoTag.length : 0;
       var tagPath = hexoTag ? hexoTag.path : ('tags/' + tagName + '/');
  %>
    <a href="<%- url_for(tagPath) %>" class="post-tag" style="margin: 10px; display: inline-block; padding: 6px 14px; border-radius: 4px; border: 1px solid; font-size: <%= min_font + Math.min(count, 10) * 1.5 %><%= unit %>;">
      <%= tagName %> (<%= count %>)
    </a>
  <% }) %>
</div>
